# weekend-city-trip 环境变量配置模板
# 使用方法:
#   1. 复制本文件为 .env: cp .env.example .env
#   2. 填入你的 API Key
#   3. .env 已在 .gitignore 中,不会被提交到版本库
#
# 注意:
#   - 所有脚本会自动从环境变量读取 Key
#   - 也可手动 export 设置(优先级高于 .env)

# 博查 WebSearch API Key (用于搜索调研 + LLM 地点清理)
# 申请地址: https://bocha.cn/
BOCHA_API_KEY=

# 高德 Web 服务 API Key (用于地理编码 geocode.py)
# 申请地址: https://console.amap.com/dev/key/app
# 类型选「Web 服务」
AMAP_KEY=

# 高德 Web 端 JS API Key (用于浏览器加载地图底图 inject.py)
# 申请地址: https://console.amap.com/dev/key/app
# 类型选「Web 端(JS API)」
AMAP_JS_KEY=

# 高德安全密钥 (与 AMAP_JS_KEY 配套,2021-12-02 后申请的 Key 必须配置)
# 在 Key 详情页可见
AMAP_SECURITY=

# 报告/地图输出目录 (可选,默认 D:/fireclaw)
# BOCHA_OUTPUT_DIR=D:/fireclaw

# 详细日志输出 (可选,设为 1/true/yes 时打印 API Key 片段等调试信息)
# VERBOSE=
